# Optional auth settings for non-interactive systemd timer runs.
# Copy this file to: ~/.config/moe-temp-sync.env
#
# For SSH:
# MOE_TEMP_REMOTE_URL=git@github.com:lyclyq/MOE-temp.git
# MOE_TEMP_SSH_KEY_PATH=/home/yuli0398/.ssh/ssh-rsa-lyclyq-MOE-temp
#
# For HTTPS + fine-grained token:
# MOE_TEMP_GITHUB_USER=YOUR_GITHUB_USERNAME
# MOE_TEMP_GITHUB_TOKEN=ghp_xxx_or_github_pat
#
# Optional overrides:
# MOE_TEMP_REMOTE_URL=https://github.com/lyclyq/MOE-temp.git
# MOE_TEMP_BRANCH=main
# MOE_TEMP_STAGING_DIR=/tmp/moe-temp-sync
# MOE_TEMP_GIT_USER_NAME=moe-sync-bot
# MOE_TEMP_GIT_USER_EMAIL=moe-sync-bot@users.noreply.github.com
